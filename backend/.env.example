PORT=5000
NODE_ENV=development

# Database Configuration (Aiven MySQL)
DB_HOST=your-mysql-host.aivencloud.com
DB_PORT=10258
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your-password
DB_SSL_MODE=REQUIRED

# JWT Configuration
